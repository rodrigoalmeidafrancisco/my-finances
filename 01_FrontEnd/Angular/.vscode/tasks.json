{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(Initial chunk files|Building|Compiling)"
          },
          "endsPattern": {
            "regexp": "(Watch mode enabled|Compiled successfully)"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(watch mode enabled|compilation|building)"
          },
          "endsPattern": {
            "regexp": "(Application bundle generation complete|Compiled successfully|Build at)"
          }
        }
      }
    }
  ]
}
